---
import { Layout } from '../components/Layout';
import { ThemeSwitcher } from '../components/ThemeSwitcher';
import '../styles/global.css';
import { ShoppingBag, TrendingUp, Terminal as TerminalIcon, Layers } from 'lucide-react';

const conversionData = [40, 70, 45, 90, 65, 80, 50];
const analyticsLabels = ['Regional Load', 'Referrers', 'Active Sessions', 'Bounce Rate'];
---

<Layout>
  <ThemeSwitcher client:load />
  
  <div class="p-4 sm:p-8 space-y-12">
    <!-- E-commerce Management -->
    <section id="ecommerce" class="space-y-6">
      <div class="flex items-center gap-2">
        <ShoppingBag size={24} class="text-brand" />
        <h2 class="text-2xl font-bold">E-commerce Management</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="btn bg-white p-6 flex flex-col gap-4 text-left cursor-default md:col-span-2">
          <h3 class="text-lg font-bold">Conversion Funnel</h3>
          <div class="h-48 bg-gray-50 flex items-end gap-2 p-4 border border-border">
            {conversionData.map((h) => (
              <div class="flex-1 bg-brand opacity-80" style={{ height: `${h}%` }}></div>
            ))}
          </div>
        </div>
        <div class="btn bg-white p-6 flex flex-col gap-4 text-left cursor-default">
          <h3 class="text-lg font-bold">Recent Logs</h3>
          <ul class="text-xs space-y-2 font-mono">
            <li class="p-2 bg-gray-50 border border-border">ORDER #4421 - Completed</li>
            <li class="p-2 bg-gray-50 border border-border">ORDER #4422 - Pending</li>
            <li class="p-2 bg-gray-50 border border-border text-brand">USER #992 - Refund Initiated</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Analytics Dashboard -->
    <section id="analytics" class="space-y-6">
      <div class="flex items-center gap-2">
        <TrendingUp size={24} class="text-brand" />
        <h2 class="text-2xl font-bold">Analytics Dashboard</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {analyticsLabels.map((label) => (
          <div class="btn bg-white p-6 flex flex-col gap-4 text-left cursor-default">
            <div class="text-[10px] uppercase tracking-widest opacity-60 font-medium">{label}</div>
            <div class="text-3xl font-bold">{(Math.random() * 100).toFixed(1)}%</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Developer Console -->
    <section id="console" class="space-y-6">
      <div class="flex items-center gap-2">
        <TerminalIcon size={24} class="text-brand" />
        <h2 class="text-2xl font-bold">Developer Console</h2>
      </div>
      <div class="bg-black text-green-400 p-6 font-mono text-sm rounded-lg overflow-hidden border-4 border-gray-800 shadow-2xl">
        <div class="flex gap-2 mb-4 border-b border-gray-800 pb-2">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
        <div>$ npm run build</div>
        <div class="opacity-70">Generating static routes...</div>
        <div class="text-white">✓ Finished in 422ms</div>
        <div class="mt-4">$ git push origin main</div>
        <div class="text-blue-400">Total 0 (delta 0), reused 0 (delta 0)</div>
      </div>
    </section>

    <!-- Component Kitchen Sink -->
    <section id="kitchen-sink" class="space-y-6">
      <div class="flex items-center gap-2">
        <Layers size={24} class="text-brand" />
        <h2 class="text-2xl font-bold">Kitchen Sink</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="btn bg-white p-6 flex flex-col gap-4 text-left cursor-default">
          <h3 class="text-lg font-bold">Buttons</h3>
          <div class="flex flex-wrap gap-4">
            <button class="btn bg-brand text-white border-brand">Primary</button>
            <button class="btn">Secondary</button>
            <button class="btn border-dashed">Dashed</button>
          </div>
        </div>
        <div class="btn bg-white p-6 flex flex-col gap-4 text-left cursor-default">
          <h3 class="text-lg font-bold">Inputs</h3>
          <input type="text" placeholder="Type something..." class="btn w-full text-left px-4 py-2 bg-gray-50" />
          <div class="flex items-center gap-2">
            <input type="checkbox" class="w-4 h-4 border-border rounded" />
            <label class="text-sm">Accept Terms</label>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
